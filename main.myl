import "IO.myllib"
import "string.myllib"
import "math.myllib"

function int addOne(int a) { return add(a, 1) }
function int addTwo(int a) { return add(a, 2) }
function int addThree(int a) { return add(a, 3) }

int input = inputNumber()
int pipeResult
pipe input > addOne > addTwo > addThree to pipeResult
print(pipeResult)

inputString()
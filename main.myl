import "IO.myllib"
import "math.myllib"
import "string.myllib"

function int f1(int x)
{
	return add(x, 1)
}

function int f2(int x)
{
	return add(x, 2)
}

function int f3(int x)
{
	return add(x, 3)
}

int x = 10
int y
int y2
pipe x > f1 > f2 > f3 to y
pipe x > f1 > f1 > f1 to y2

print(y)
print(y2)
